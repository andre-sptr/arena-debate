# Google Gemini API Configuration
GOOGLE_API_KEY=your-gemini-api-key-here
# Get your API key from: https://aistudio.google.com/app/apikey

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./arena.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/arena

# Cache Configuration (Optional - uses in-memory cache by default)
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$|^https://.*\.vercel\.app$

# Rate Limiting
MAX_DEBATES_PER_MINUTE=1
MAX_CONCURRENT_DEBATES=5

# AI Model Configuration
DEFAULT_MODEL=gemini-3.1-flash-lite-preview
CONSENSUS_MODEL=gemini-3-flash-preview
MAX_OUTPUT_TOKENS=300
TEMPERATURE=0.8
THINKING_BUDGET=1024
AI_REQUEST_TIMEOUT=60
